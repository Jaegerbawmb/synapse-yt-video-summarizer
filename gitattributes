# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Force LF for Python and shell scripts
*.py text eol=lf
*.sh text eol=lf

# Force LF for web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary — don't touch
*.png binary
*.jpg binary
*.mp3 binary
*.wav binary
*.bin binary
*.safetensors binary
*.pt binary
